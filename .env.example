# ── Environment Variables — fmanager ──────────────────────────────────────
# Copy this file to .env and fill in the values before running docker compose

# PostgreSQL
DB_USERNAME=fmanager_user
DB_PASSWORD=change_me_in_production

# pgAdmin UI
PGADMIN_EMAIL=admin@corp.com
PGADMIN_PASSWORD=change_me_in_production

# File Manager base path (inside container — do not change unless remapping volume)
FILE_MANAGER_BASE_PATH=/data/filemanager
